# =============================================================================
# ⚠️  DEPRECATED: 此 .env 配置模板已弃用
# =============================================================================
#
# 推荐迁移至 YAML 配置格式，具备以下优势：
#   - 支持注释和层次化结构（更易读）
#   - 支持多行字符串和复杂数据类型
#   - 支持深度合并（部分覆盖而非整体替换）
#   - 内置默认配置作为基准，仅需声明差异项
#
# 迁移方式：
#   1. 运行 negentropy-perceives --init-config 生成默认 YAML 配置
#   2. 编辑 ~/.negentropy/perceives.config.yaml（或使用 -c 指定自定义路径）
#
# ⚠️  .env 文件仍受支持（向后兼容），但已降级为第四优先级。
#     新配置优先级（低 → 高）：
#       config.default.yaml → 用户 YAML → -c CLI → .env → 环境变量
#
# ── 以下内容保留供仍需使用 .env 的场景参考 ──
# =============================================================================
#
# Negentropy Perceives 配置模板（.env 格式，已弃用）
#
# 使用方法（仅限 .env 场景）：
#   1. 复制本文件为 .env：cp .env.example .env
#   2. 根据实际需求修改配置值
#   3. 未注释的配置项展示当前默认值，可直接修改
#   4. 以 # 开头的配置项为可选配置，取消注释即可启用
#
# 环境变量前缀：NEGENTROPY_PERCEIVES_
# =============================================================================

# ── 服务标识 ──────────────────────────────────────────────────────────────────
# 服务器标识名称
NEGENTROPY_PERCEIVES_SERVER_NAME=negentropy-perceives
# 版本号自动从 pyproject.toml 读取，无需手动配置
# NEGENTROPY_PERCEIVES_SERVER_VERSION=0.1.6.1

# ── 传输层 ────────────────────────────────────────────────────────────────────
# MCP 传输协议模式：stdio / http / sse
NEGENTROPY_PERCEIVES_TRANSPORT_MODE=http
# HTTP 服务器绑定主机（生产环境可设为 0.0.0.0 以接受外部连接）
NEGENTROPY_PERCEIVES_HTTP_HOST=localhost
# HTTP 服务器监听端口
NEGENTROPY_PERCEIVES_HTTP_PORT=8081
# HTTP 端点路径
NEGENTROPY_PERCEIVES_HTTP_PATH=/mcp
# CORS 来源白名单（* 允许所有，null 禁用 CORS）
NEGENTROPY_PERCEIVES_HTTP_CORS_ORIGINS=*

# ── 抓取引擎 ──────────────────────────────────────────────────────────────────
# 并发请求上限（> 0）
NEGENTROPY_PERCEIVES_CONCURRENT_REQUESTS=16
# 下载间隔，单位秒（>= 0）
NEGENTROPY_PERCEIVES_DOWNLOAD_DELAY=1.0
# 随机化下载间隔
NEGENTROPY_PERCEIVES_RANDOMIZE_DOWNLOAD_DELAY=true
# 启用自动节流
NEGENTROPY_PERCEIVES_AUTOTHROTTLE_ENABLED=true
# 自动节流初始延迟，单位秒
NEGENTROPY_PERCEIVES_AUTOTHROTTLE_START_DELAY=1.0
# 自动节流最大延迟，单位秒
NEGENTROPY_PERCEIVES_AUTOTHROTTLE_MAX_DELAY=60.0
# 自动节流目标并发度
NEGENTROPY_PERCEIVES_AUTOTHROTTLE_TARGET_CONCURRENCY=1.0

# ── 速率限制 ──────────────────────────────────────────────────────────────────
# 每分钟请求频率上限（>= 1）
NEGENTROPY_PERCEIVES_RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ── 重试策略 ──────────────────────────────────────────────────────────────────
# 失败重试最大次数（>= 0）
NEGENTROPY_PERCEIVES_MAX_RETRIES=3
# 重试间隔，单位秒（>= 0）
NEGENTROPY_PERCEIVES_RETRY_DELAY=1.0

# ── 缓存系统 ──────────────────────────────────────────────────────────────────
# 启用响应缓存
NEGENTROPY_PERCEIVES_ENABLE_CACHING=true
# 缓存生存时间，单位小时（> 0）
NEGENTROPY_PERCEIVES_CACHE_TTL_HOURS=24
# 缓存最大条目数（留空表示不限）
# NEGENTROPY_PERCEIVES_CACHE_MAX_SIZE=

# ── 日志系统 ──────────────────────────────────────────────────────────────────
# 日志级别：DEBUG / INFO / WARNING / ERROR / CRITICAL
NEGENTROPY_PERCEIVES_LOG_LEVEL=INFO
# 记录请求详情（可选）
# NEGENTROPY_PERCEIVES_LOG_REQUESTS=false
# 记录响应详情（可选）
# NEGENTROPY_PERCEIVES_LOG_RESPONSES=false

# ── 浏览器引擎 ────────────────────────────────────────────────────────────────
# 启用 JavaScript 执行
NEGENTROPY_PERCEIVES_ENABLE_JAVASCRIPT=false
# 无头浏览器模式
NEGENTROPY_PERCEIVES_BROWSER_HEADLESS=true
# 浏览器操作超时，单位秒
NEGENTROPY_PERCEIVES_BROWSER_TIMEOUT=30
# 浏览器窗口尺寸
NEGENTROPY_PERCEIVES_BROWSER_WINDOW_SIZE=1920x1080

# ── 用户代理 ──────────────────────────────────────────────────────────────────
# 启用随机 User-Agent 轮换
NEGENTROPY_PERCEIVES_USE_RANDOM_USER_AGENT=true
# 默认 User-Agent 字符串
NEGENTROPY_PERCEIVES_DEFAULT_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"

# ── 代理服务 ──────────────────────────────────────────────────────────────────
# 启用代理服务器
NEGENTROPY_PERCEIVES_USE_PROXY=false
# 代理服务器 URL（启用代理时必填，如 http://proxy.example.com:8080）
# NEGENTROPY_PERCEIVES_PROXY_URL=

# ── 请求设置 ──────────────────────────────────────────────────────────────────
# HTTP 请求超时，单位秒（> 0）
NEGENTROPY_PERCEIVES_REQUEST_TIMEOUT=30

# ── LLM 编排（Smart 模式，需安装 litellm 可选依赖）─────────────────────────
# LLM API Key（ZhipuAI），也可通过 ZHIPU_API_KEY 环境变量设置
# NEGENTROPY_PERCEIVES_LLM_API_KEY=
# LiteLLM 模型标识
# NEGENTROPY_PERCEIVES_LLM_MODEL=zhipu/glm-5-plus-250414
# LLM 温度参数（0.0 ~ 2.0）
# NEGENTROPY_PERCEIVES_LLM_TEMPERATURE=0.1
# LLM 最大输出 token（> 0）
# NEGENTROPY_PERCEIVES_LLM_MAX_TOKENS=4096
# LLM API 超时，单位秒（> 0）
# NEGENTROPY_PERCEIVES_LLM_TIMEOUT=60.0
# LLM API 重试次数（>= 0）
# NEGENTROPY_PERCEIVES_LLM_MAX_RETRIES=2

# ── 硬件加速 ──────────────────────────────────────────────────────────────────
# 推理设备：auto / cpu / cuda (NVIDIA) / mps (Apple Silicon) / xpu (Intel)
# NEGENTROPY_PERCEIVES_ACCELERATOR_DEVICE=auto
# CPU 推理线程数（>= 1）
# NEGENTROPY_PERCEIVES_ACCELERATOR_NUM_THREADS=4

# ── Docling PDF 引擎（需安装 docling 可选依赖）────────────────────────────────
# 启用 Docling 作为可选 PDF 提取引擎
# NEGENTROPY_PERCEIVES_DOCLING_ENABLED=false
# 为扫描版 PDF 启用 OCR
# NEGENTROPY_PERCEIVES_DOCLING_OCR_ENABLED=true
# 启用 Docling 高级表格提取
# NEGENTROPY_PERCEIVES_DOCLING_TABLE_EXTRACTION_ENABLED=true
# 启用 Docling 数学公式提取（MPS 上自动禁用以保持 GPU 加速）
# NEGENTROPY_PERCEIVES_DOCLING_FORMULA_EXTRACTION_ENABLED=true
